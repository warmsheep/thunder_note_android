<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/flashNoteIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_logo_primary_soft"
            android:gravity="center"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/flashNoteTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_size_caption"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/matchedContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@color/search_highlight"
        android:ellipsize="end"
        android:maxLines="3"
        android:padding="8dp"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_size_body" />

    <LinearLayout
        android:id="@+id/contextContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="vertical" />

</LinearLayout>
