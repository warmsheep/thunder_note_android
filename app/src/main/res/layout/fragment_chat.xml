<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/top_bar_background"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:id="@+id/backButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="6dp"
            android:src="@drawable/ic_chat_back" />

        <TextView
            android:id="@+id/titleText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_size_body" />

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="6dp"
            android:src="@drawable/ic_chat_more" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/border" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:gravity="bottom"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:id="@+id/inputContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="bottom"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/addButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_logo_primary_soft"
                android:padding="6dp"
                android:src="@drawable/ic_chat_add" />

            <EditText
                android:id="@+id/messageInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input_rounded"
                android:gravity="top|start"
                android:hint="输入内容..."
                android:imeOptions="flagNoEnterAction"
                android:inputType="textCapSentences|textMultiLine"
                android:minHeight="40dp"
                android:overScrollMode="ifContentScrolls"
                android:paddingLeft="14dp"
                android:paddingTop="10dp"
                android:paddingRight="14dp"
                android:paddingBottom="10dp"
                android:scrollbars="vertical"
                android:textSize="@dimen/text_size_body_small" />

            <ImageView
                android:id="@+id/micButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_logo_primary_soft"
                android:padding="6dp"
                android:src="@drawable/ic_chat_mic" />

            <ImageView
                android:id="@+id/sendButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_button_primary_rounded"
                android:padding="6dp"
                android:src="@drawable/ic_chat_send" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/toolsPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@color/surface"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="12dp"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/toolImageVideo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="8dp">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="6dp"
                    android:src="@android:drawable/ic_menu_gallery" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="图片/视频"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_tiny" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/toolFile"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="8dp">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="6dp"
                    android:src="@android:drawable/ic_menu_upload" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="文件"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_tiny" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/toolCamera"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="8dp">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="6dp"
                    android:src="@android:drawable/ic_menu_camera" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="拍照"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_tiny" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/toolCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="8dp">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="6dp"
                    android:src="@android:drawable/ic_menu_agenda" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="卡片"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_tiny" />
            </LinearLayout>
        </LinearLayout>

        <!-- Recording overlay - shown during/after recording -->
        <FrameLayout
            android:id="@+id/recordingOverlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface"
            android:visibility="gone"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Cancel button (X) -->
                <ImageButton
                    android:id="@+id/recordCancelBtn"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_record_cancel"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:scaleType="centerInside"
                    android:contentDescription="Cancel" />

                <!-- Waveform area -->
                <LinearLayout
                    android:id="@+id/recordWaveformContainer"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="16dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <!-- Recording waveform visualization -->
                    <com.flashnote.java.ui.chat.VoiceWaveView
                        android:id="@+id/recordWaveView"
                        android:layout_width="match_parent"
                        android:layout_height="32dp" />

                    <!-- Recording timer -->
                    <TextView
                        android:id="@+id/recordTimerText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:text="0:00" />
                </LinearLayout>

                <!-- Send button -->
                <ImageButton
                    android:id="@+id/recordSendBtn"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_record_send"
                    android:src="@android:drawable/ic_menu_send"
                    android:scaleType="centerInside"
                    android:contentDescription="Send" />
            </LinearLayout>
        </FrameLayout>

        <!-- Multi-select merge panel -->
        <LinearLayout
            android:id="@+id/mergePanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/mergeTitleText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="已选择 0 条消息"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_body_small" />

            <TextView
                android:id="@+id/mergeCancelButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:padding="6dp"
                android:text="取消"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_body_small" />

            <TextView
                android:id="@+id/mergeDeleteButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_logo_primary_soft"
                android:paddingLeft="12dp"
                android:paddingTop="6dp"
                android:paddingRight="12dp"
                android:paddingBottom="6dp"
                android:text="删除"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_size_body_small" />

            <TextView
                android:id="@+id/mergeConfirmButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_button_primary_rounded"
                android:paddingLeft="12dp"
                android:paddingTop="6dp"
                android:paddingRight="12dp"
                android:paddingBottom="6dp"
                android:text="合并"
                android:textColor="@android:color/white"
                android:textSize="@dimen/text_size_body_small" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
