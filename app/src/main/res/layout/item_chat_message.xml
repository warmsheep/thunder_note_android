<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="4dp"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/timeDivider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:textColor="@color/text_time_divider"
        android:textSize="@dimen/text_size_tiny"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/leftContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="top"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/avatarText"
            android:layout_width="@dimen/icon_size_avatar"
            android:layout_height="@dimen/icon_size_avatar"
            android:background="@drawable/bg_logo_primary_soft"
            android:gravity="center"
            android:text="🤖"
            android:textSize="@dimen/icon_text_size_avatar" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/bubbleCard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            app:cardCornerRadius="10dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="12dp"
                android:paddingTop="8dp"
                android:paddingRight="12dp"
                android:paddingBottom="8dp">

                <FrameLayout
                    android:id="@+id/mediaImageContainer"
                    android:layout_width="@dimen/chat_media_preview_width"
                    android:layout_height="@dimen/chat_media_preview_height"
                    android:layout_marginBottom="@dimen/chat_media_spacing_small"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/mediaImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop" />

                    <ImageView
                        android:id="@+id/playIcon"
                        android:layout_width="@dimen/chat_media_play_icon_size"
                        android:layout_height="@dimen/chat_media_play_icon_size"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_play_circle"
                        android:visibility="gone" />

                    <ProgressBar
                        android:id="@+id/uploadProgress"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center"
                        android:visibility="gone" />
                </FrameLayout>

                <LinearLayout
                    android:id="@+id/voiceContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/chat_media_spacing_small"
                    android:gravity="center_vertical"
                    android:minWidth="@dimen/chat_voice_min_width"
                    android:orientation="horizontal"
                    android:padding="@dimen/chat_voice_padding"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/voicePlayBtn"
                        android:layout_width="@dimen/chat_voice_play_btn_size"
                        android:layout_height="@dimen/chat_voice_play_btn_size"
                        android:src="@drawable/ic_play_arrow" />

                    <View
                        android:id="@+id/voiceWaveform"
                        android:layout_width="@dimen/chat_voice_waveform_width"
                        android:layout_height="@dimen/chat_voice_waveform_height"
                        android:layout_marginStart="@dimen/chat_media_spacing_small"
                        android:background="@drawable/bg_voice_waveform" />

                    <TextView
                        android:id="@+id/voiceDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/chat_media_spacing_small"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_size_caption" />

                    <ProgressBar
                        android:id="@+id/voiceUploadProgress"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="4dp"
                        android:visibility="gone" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/fileContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/chat_media_spacing_small"
                    android:gravity="center_vertical"
                    android:minWidth="@dimen/chat_file_min_width"
                    android:orientation="horizontal"
                    android:padding="@dimen/chat_file_padding"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/fileIcon"
                        android:layout_width="@dimen/chat_file_icon_size"
                        android:layout_height="@dimen/chat_file_icon_size"
                        android:src="@drawable/ic_file_generic" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/chat_file_name_margin_start"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/fileNameText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:ellipsize="middle"
                            android:maxWidth="@dimen/chat_file_name_max_width"
                            android:singleLine="true"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_body_small" />

                        <TextView
                            android:id="@+id/fileSizeText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_tiny" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/fileUploadProgress"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="8dp"
                        android:visibility="gone" />
                </LinearLayout>

                <TextView
                    android:id="@+id/messageText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="@dimen/chat_message_text_max_width"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_body_small" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/rightContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end|top"
        android:orientation="horizontal"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_chat_mine"
            android:orientation="vertical"
            android:paddingLeft="12dp"
            android:paddingTop="8dp"
            android:paddingRight="12dp"
            android:paddingBottom="8dp">

            <FrameLayout
                android:id="@+id/rightMediaImageContainer"
                android:layout_width="@dimen/chat_media_preview_width"
                android:layout_height="@dimen/chat_media_preview_height"
                android:layout_marginBottom="@dimen/chat_media_spacing_small"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/rightMediaImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop" />

                <ImageView
                    android:id="@+id/rightPlayIcon"
                    android:layout_width="@dimen/chat_media_play_icon_size"
                    android:layout_height="@dimen/chat_media_play_icon_size"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_play_circle"
                    android:visibility="gone" />

                <ProgressBar
                    android:id="@+id/rightUploadProgress"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:visibility="gone" />
            </FrameLayout>

            <LinearLayout
                android:id="@+id/rightVoiceContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/chat_media_spacing_small"
                android:gravity="center_vertical"
                android:minWidth="@dimen/chat_voice_min_width"
                android:orientation="horizontal"
                android:padding="@dimen/chat_voice_padding"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/rightVoicePlayBtn"
                    android:layout_width="@dimen/chat_voice_play_btn_size"
                    android:layout_height="@dimen/chat_voice_play_btn_size"
                    android:src="@drawable/ic_play_arrow" />

                <View
                    android:id="@+id/rightVoiceWaveform"
                    android:layout_width="@dimen/chat_voice_waveform_width"
                    android:layout_height="@dimen/chat_voice_waveform_height"
                    android:layout_marginStart="@dimen/chat_media_spacing_small"
                    android:background="@drawable/bg_voice_waveform" />

                <TextView
                    android:id="@+id/rightVoiceDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/chat_media_spacing_small"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_caption" />

                <ProgressBar
                    android:id="@+id/rightVoiceUploadProgress"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="4dp"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rightFileContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/chat_media_spacing_small"
                android:gravity="center_vertical"
                android:minWidth="@dimen/chat_file_min_width"
                android:orientation="horizontal"
                android:padding="@dimen/chat_file_padding"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/rightFileIcon"
                    android:layout_width="@dimen/chat_file_icon_size"
                    android:layout_height="@dimen/chat_file_icon_size"
                    android:src="@drawable/ic_file_generic" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/chat_file_name_margin_start"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/rightFileNameText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="middle"
                        android:maxWidth="@dimen/chat_file_name_max_width"
                        android:singleLine="true"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_body_small" />

                    <TextView
                        android:id="@+id/rightFileSizeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_size_tiny" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/rightFileUploadProgress"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="8dp"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:id="@+id/rightMessageText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="@dimen/chat_message_text_max_width"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_body_small" />
        </LinearLayout>

        <TextView
            android:id="@+id/rightAvatarText"
            android:layout_width="@dimen/icon_size_avatar"
            android:layout_height="@dimen/icon_size_avatar"
            android:background="@drawable/bg_logo_primary_soft"
            android:gravity="center"
            android:text="😊"
            android:textSize="@dimen/icon_text_size_avatar" />
    </LinearLayout>

</LinearLayout>
