<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/timeDivider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:textColor="@color/text_time_divider"
        android:textSize="11sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/leftContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="top"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/avatarText"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_logo_primary_soft"
            android:gravity="center"
            android:text="🤖"
            android:textSize="16sp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/bubbleCard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            app:cardCornerRadius="10dp">

            <TextView
                android:id="@+id/messageText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingLeft="12dp"
                android:paddingTop="8dp"
                android:paddingRight="12dp"
                android:paddingBottom="8dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/rightContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end|top"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:id="@+id/rightMessageText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_chat_mine"
            android:paddingLeft="12dp"
            android:paddingTop="8dp"
            android:paddingRight="12dp"
            android:paddingBottom="8dp"
            android:textColor="@color/text_primary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/rightAvatarText"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_logo_primary_soft"
            android:gravity="center"
            android:text="😊"
            android:textSize="16sp" />
    </LinearLayout>

</LinearLayout>
