<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

    <!-- 1. 渐变头部区域 -->
    <FrameLayout
        android:id="@+id/profileHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_profile_header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- 头像 -->
            <FrameLayout
                android:id="@+id/avatarContainer"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:background="@drawable/bg_avatar_circle"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/avatarText"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="😊"
                    android:textSize="32sp" />

                <ImageView
                    android:id="@+id/avatarImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />
            </FrameLayout>

            <TextView
                android:id="@+id/syncHintText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/action_sync"
                android:textColor="#D9FFFFFF"
                android:textSize="12sp" />

            <!-- 用户名 -->
            <TextView
                android:id="@+id/usernameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/status_profile_loading"
                android:textColor="@color/white"
                android:textSize="@dimen/text_size_page_title"
                android:textStyle="bold" />

            <!-- 简介 -->
            <TextView
                android:id="@+id/bioText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/status_empty_bio"
                android:textColor="#B0FFFFFF"
                android:textSize="@dimen/text_size_body" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/syncButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="end|top"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="14dp"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:contentDescription="@string/action_sync"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp">

            <ImageView
                android:id="@+id/syncIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_sync"
                android:tint="@color/white" />

            <ProgressBar
                android:id="@+id/syncProgress"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:indeterminate="true"
                android:indeterminateTint="@color/white"
                android:visibility="gone" />

            <TextView
                android:id="@+id/syncPendingBadge"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="end|top"
                android:layout_marginTop="-4dp"
                android:layout_marginEnd="-4dp"
                android:background="@drawable/bg_sync_badge"
                android:gravity="center"
                android:text="@string/count_zero"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </FrameLayout>
    </FrameLayout>

    <!-- 2. 统计行 -->
    <LinearLayout
        android:id="@+id/statsRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:padding="16dp"
        android:orientation="horizontal">

        <!-- 闪记数 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/flashNoteCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/count_zero"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_page_title"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_stat_flashnote"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_caption" />
        </LinearLayout>

        <!-- 收藏数 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/favoriteCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/count_zero"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_page_title"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_stat_favorite"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_caption" />
        </LinearLayout>

        <!-- 记录数 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/recordCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/count_zero"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_page_title"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_stat_record"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_caption" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/border" />

    <!-- 3. 菜单列表 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical"
        android:background="@color/white">

        <!-- 修改密码 -->
        <LinearLayout
            android:id="@+id/menuChangePassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_menu_icon"
                android:gravity="center"
                android:text="🔒"
                android:textSize="18sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:text="@string/action_change_password"
                android:textSize="@dimen/text_size_body"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/symbol_chevron"
                android:textSize="14sp"
                android:textColor="#CCCCCC" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginStart="62dp"
            android:background="@color/border" />

        <!-- 设置 -->
        <LinearLayout
            android:id="@+id/menuSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_menu_icon"
                android:gravity="center"
                android:text="⚙️"
                android:textSize="18sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:text="@string/action_settings"
                android:textSize="@dimen/text_size_body"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/symbol_chevron"
                android:textSize="14sp"
                android:textColor="#CCCCCC" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginStart="62dp"
            android:background="@color/border" />

        <!-- 退出登录 -->
        <LinearLayout
            android:id="@+id/menuLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_menu_icon"
                android:gravity="center"
                android:text="🚪"
                android:textSize="18sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:text="@string/action_logout"
                android:textSize="@dimen/text_size_body"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/symbol_chevron"
                android:textSize="14sp"
                android:textColor="#CCCCCC" />
        </LinearLayout>
    </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
